{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "serviceBusNamespaceName": { "type": "string" }
  },
  "resources": [
    {
      "type": "Microsoft.ServiceBus/namespaces",
      "apiVersion": "2022-10-01-preview",
      "name": "[parameters('serviceBusNamespaceName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Basic", "tier": "Basic" },
      "properties": { "minimumTlsVersion": "1.2" }
    },
    {
      "type": "Microsoft.ServiceBus/namespaces/queues",
      "apiVersion": "2022-10-01-preview",
      "name": "[concat(parameters('serviceBusNamespaceName'), '/events')]",
      "dependsOn": ["[resourceId('Microsoft.ServiceBus/namespaces', parameters('serviceBusNamespaceName'))]"],
      "properties": {
        "maxSizeInMegabytes": 1024,
        "defaultMessageTimeToLive": "P14D"
      }
    }
  ],
  "outputs": {
    "serviceBusNamespace": { "type": "string", "value": "[parameters('serviceBusNamespaceName')]" }
  }
}
