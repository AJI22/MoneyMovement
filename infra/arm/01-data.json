{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "POSTGRES_ADMIN": { "type": "string", "defaultValue": "pgadmin" },
    "POSTGRES_PASSWORD": { "type": "secureString" },
    "DATABASE_NAME": { "type": "string", "defaultValue": "ledger" }
  },
  "variables": {
    "postgresServerName": "[concat('pg-mm-', parameters('environmentName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-03-01-preview",
      "name": "[variables('postgresServerName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "B_Standard_B1ms", "tier": "Burstable" },
      "properties": {
        "version": "16",
        "administratorLogin": "[parameters('POSTGRES_ADMIN')]",
        "administratorLoginPassword": "[parameters('POSTGRES_PASSWORD')]",
        "storage": { "storageSizeGB": 32 },
        "backup": { "backupRetentionDays": 7 }
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/ledger')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": { "charset": "UTF8", "collation": "en_US.utf8" }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/rails_ng')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": { "charset": "UTF8", "collation": "en_US.utf8" }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/rails_us')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": { "charset": "UTF8", "collation": "en_US.utf8" }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/fx')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": { "charset": "UTF8", "collation": "en_US.utf8" }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/orchestrator')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": { "charset": "UTF8", "collation": "en_US.utf8" }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/temporal')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": { "charset": "UTF8", "collation": "en_US.utf8" }
    }
  ],
  "outputs": {
    "postgresServerName": { "type": "string", "value": "[variables('postgresServerName')]" },
    "postgresFqdn": { "type": "string", "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))).fullyQualifiedDomainName]" }
  }
}
